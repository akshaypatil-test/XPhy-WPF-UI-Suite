<UserControl x:Class="x_phy_wpf_ui.Controls.StatisticsCards"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="76.583" d:DesignWidth="945.516">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" Opacity="0.08"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#999999"/>
        <SolidColorBrush x:Key="PrimaryPink" Color="#E2156B"/>
        <SolidColorBrush x:Key="ValueAccentBrush" Color="#1AB4CC"/>
        <!-- Card border: 35% pink + 30% transparent + 35% cyan -->
        <LinearGradientBrush x:Key="NavBarBorderGradient" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#E2156B" Offset="0"/>
            <GradientStop Color="Transparent" Offset="0.35"/>
            <GradientStop Color="Transparent" Offset="0.65"/>
            <GradientStop Color="#1AB4CC" Offset="1"/>
        </LinearGradientBrush>
        <!-- Glass ellipse: dark reddish-purple radial gradient -->
        <RadialGradientBrush x:Key="KpiEllipseGlassBg" GradientOrigin="0.3,0.3" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
            <GradientStop Color="#5A2D4A" Offset="0"/>
            <GradientStop Color="#3D2038" Offset="0.5"/>
            <GradientStop Color="#2D1B2E" Offset="1"/>
        </RadialGradientBrush>
        <!-- Glass ellipse: glossy border (highlight top-left, softer bottom-right) -->
        <LinearGradientBrush x:Key="KpiEllipseGlassBorder" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#80FFFFFF" Offset="0"/>
            <GradientStop Color="#40FFFFFF" Offset="0.4"/>
            <GradientStop Color="#15FFFFFF" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Total Detections Card -->
        <Border Grid.Column="0" 
                Background="{StaticResource CardBackground}" 
                CornerRadius="28"
                BorderBrush="{StaticResource NavBarBorderGradient}"
                BorderThickness="1"
                Padding="12,14,12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse Fill="{StaticResource KpiEllipseGlassBg}"/>
                    <Ellipse Fill="{StaticResource PrimaryPink}" Opacity="0.12"/>
                    <Ellipse>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/kpi-logo.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Fill="Transparent" Stroke="{StaticResource KpiEllipseGlassBorder}" StrokeThickness="1"/>
                </Grid>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Total Detections" 
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalDetectionsText" 
                           Text="0" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource ValueAccentBrush}"
                           Margin="0,3,0,0"/>
            </Grid>
        </Border>

        <!-- Total Deepfakes Card -->
        <Border Grid.Column="2" 
                Background="{StaticResource CardBackground}" 
                CornerRadius="28"
                BorderBrush="{StaticResource NavBarBorderGradient}"
                BorderThickness="1"
                Padding="12,14,12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse Fill="{StaticResource KpiEllipseGlassBg}"/>
                    <Ellipse Fill="{StaticResource PrimaryPink}" Opacity="0.12"/>
                    <Ellipse>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/kpi-logo.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Fill="Transparent" Stroke="{StaticResource KpiEllipseGlassBorder}" StrokeThickness="1"/>
                </Grid>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Total Deepfakes" 
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalDeepfakesText" 
                           Text="0" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource ValueAccentBrush}"
                           Margin="0,3,0,0"/>
            </Grid>
        </Border>

        <!-- Total Analysis Time Card -->
        <Border Grid.Column="4" 
                Background="{StaticResource CardBackground}" 
                CornerRadius="28"
                BorderBrush="{StaticResource NavBarBorderGradient}"
                BorderThickness="1"
                Padding="12,14,12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse Fill="{StaticResource KpiEllipseGlassBg}"/>
                    <Ellipse Fill="{StaticResource PrimaryPink}" Opacity="0.12"/>
                    <Ellipse>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/kpi-logo.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Fill="Transparent" Stroke="{StaticResource KpiEllipseGlassBorder}" StrokeThickness="1"/>
                </Grid>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Total Analysis Time" 
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalAnalysisTimeText" 
                           Text="0h" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource ValueAccentBrush}"
                           Margin="0,3,0,0"/>
            </Grid>
        </Border>

        <!-- Last Detection Card -->
        <Border Grid.Column="6" 
                Background="{StaticResource CardBackground}" 
                CornerRadius="28"
                BorderBrush="{StaticResource NavBarBorderGradient}"
                BorderThickness="1"
                Padding="12,14,12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse Fill="{StaticResource KpiEllipseGlassBg}"/>
                    <Ellipse Fill="{StaticResource PrimaryPink}" Opacity="0.12"/>
                    <Ellipse>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/kpi-logo.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Fill="Transparent" Stroke="{StaticResource KpiEllipseGlassBorder}" StrokeThickness="1"/>
                </Grid>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Last Detection" 
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LastDetectionText" 
                           Text="Never" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource ValueAccentBrush}"
                           Margin="0,3,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
