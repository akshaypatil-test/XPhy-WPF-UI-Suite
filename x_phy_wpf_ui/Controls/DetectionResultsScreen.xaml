<UserControl x:Class="x_phy_wpf_ui.Controls.DetectionResultsScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Using theme-aware brushes -->
        <SolidColorBrush x:Key="CardBg" Color="{DynamicResource Color.Card}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource Color.TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource Color.TextSecondary}"/>
        <SolidColorBrush x:Key="PrimaryPinkBrush" Color="{DynamicResource Color.Primary}"/>
        <SolidColorBrush x:Key="ResultRedBrush" Color="{DynamicResource Color.Error}"/>
        <SolidColorBrush x:Key="ResultGreenBrush" Color="{DynamicResource Color.Success}"/>
        <SolidColorBrush x:Key="TealBrush" Color="{DynamicResource Color.Secondary}"/>
        <SolidColorBrush x:Key="TypePillBg" Color="{DynamicResource Color.Surface}"/>
        <!-- Results grid: headers larger than body rows -->
        <Style x:Key="ResultsGridHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="TealButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.ResultsRowHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.White}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <SolidColorBrush x:Key="PanelBorder" Color="{DynamicResource Color.Border}"/>
        <SolidColorBrush x:Key="PanelGlowBorder" Color="{DynamicResource Color.Secondary}"/>
        <SolidColorBrush x:Key="FieldBlockBg" Color="{DynamicResource Color.Surface}"/>
        <SolidColorBrush x:Key="MetadataRowBg" Color="{DynamicResource Color.Card}"/>
        <SolidColorBrush x:Key="MetadataLabelBrush" Color="{DynamicResource Color.TextPrimary}"/>
        <!-- Row hover uses Brush.ResultsRowHover (theme-aware; slightly darker in light mode so hover is visible, dark in dark mode) -->
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title row fixed; table row * fills space. DataGrid scrolls inside itself — column headers stay sticky (standard WPF behavior). -->
        <Grid x:Name="ResultsListView" Grid.Row="0" Margin="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Focusable="True" FocusVisualStyle="{x:Null}" UseLayoutRounding="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Title and Legend -->
                <Grid x:Name="ResultsTitleRow" Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="DETECTION RESULTS"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Ellipse Width="9" Height="9" Fill="{StaticResource ResultRedBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="AI Manipulation Detected" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Ellipse Width="9" Height="9" Fill="{StaticResource ResultGreenBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="No AI Manipulation Detected" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Results area: table when items exist, or "No results to show" when empty -->
                <Grid x:Name="ResultsBodyGrid" Grid.Row="1" MinHeight="0" Margin="0,0,0,0" VerticalAlignment="Stretch">
                    <!-- Empty state: centered message -->
                    <Border x:Name="NoResultsPanel" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            CornerRadius="8" Padding="24,20" Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{StaticResource PanelBorder}" BorderThickness="1">
                        <TextBlock Text="No results to show" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <!-- Results Table: cyan top border + glass look -->
                    <!-- ClipToBounds false: rounded rect + scroll viewer would clip the last rows at the bottom -->
                    <Border x:Name="ResultsTablePanel" CornerRadius="8" Margin="0,0,0,0" BorderBrush="{StaticResource PanelGlowBorder}" BorderThickness="0,1,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Focusable="False">
                    <!-- No Effect / no translucent gradient on this border: DropShadow + glass on a ScrollViewer parent
                         causes WPF to bitmap-cache children and row content disappears or clips while scrolling. -->
                    <Border CornerRadius="8" Padding="0,0,0,2" Background="Transparent" UseLayoutRounding="True"
                            VerticalAlignment="Stretch" ClipToBounds="False" Focusable="False"
                            SnapsToDevicePixels="True">
                    <DataGrid x:Name="ResultsDataGrid"
                              AutoGenerateColumns="False"
                              EnableRowVirtualization="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              RowBackground="{DynamicResource Brush.Card}"
                              AlternatingRowBackground="{DynamicResource Brush.Card}"
                              BorderThickness="0"
                              Background="{DynamicResource Brush.Card}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              RowHeight="44"
                              FontSize="12"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              UseLayoutRounding="True"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              FocusVisualStyle="{x:Null}">
                        <DataGrid.Resources>
                            <!-- Pixel scrolling avoids logical scroll + hidden bar fighting row measure (squashed / blank rows in video). -->
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
                                <Setter Property="CanContentScroll" Value="False"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="MinHeight" Value="48"/>
                                <Setter Property="Padding" Value="6,14,6,14"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="0,0,0,1"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
                                <Setter Property="MinHeight" Value="44"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <!-- Default-style row: no SelectiveScrollingGrid (it desyncs with column-header scroll when scrollbar is hidden). -->
                                        <ControlTemplate TargetType="DataGridRow">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="0,0,0,1"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    SnapsToDevicePixels="True">
                                                <DataGridCellsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                                        ItemsPanel="{TemplateBinding ItemsPanel}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <!-- IsSelected after IsMouseOver so selected row keeps visible highlight when both apply -->
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Brush.ResultsRowHover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="3,8,3,8"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <!-- Template column (not DataGridTextColumn): text column applies HighlightTextBrush when selected;
                                 which is white on our light Surface row background — timestamp vanished in light mode. -->
                            <DataGridTemplateColumn Width="1.35*" MinWidth="150" SortMemberPath="TimestampLocal" CanUserSort="True">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="Timestamp" Style="{StaticResource ResultsGridHeaderTextStyle}" VerticalAlignment="Center"/>
                                            <TextBlock Text="▼" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" Opacity="0.9"/>
                                        </StackPanel>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TimestampDisplay}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextTrimming="None"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="78" MinWidth="72">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <TextBlock Text="Type" Style="{StaticResource ResultsGridHeaderTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource TypePillBg}" CornerRadius="14" Padding="8,4" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Type}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" TextTrimming="None"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="1.15*" MinWidth="132" SortMemberPath="MediaSourceForDisplay">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <TextBlock Text="Media Source" Style="{StaticResource ResultsGridHeaderTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MediaSourceForDisplay}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding MediaSourceForDisplay}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="2.1*" MinWidth="158">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <TextBlock Text="Result" Style="{StaticResource ResultsGridHeaderTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ResultText}" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAiManipulationDetected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ResultRedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsAiManipulationDetected}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource ResultGreenBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="0.75*"
                                                    MinWidth="76"
                                                    SortMemberPath="ConfidencePercent">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <TextBlock Text="Confidence" Style="{StaticResource ResultsGridHeaderTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ConfidenceText}" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAiManipulationDetected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ResultRedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsAiManipulationDetected}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource ResultGreenBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="102" MinWidth="96">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <TextBlock Text="Evidence" Style="{StaticResource ResultsGridHeaderTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="12"
                                                Padding="2,0"
                                                HorizontalAlignment="Center"
                                                FocusVisualStyle="{x:Null}"
                                                Click="ViewResult_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="View Result"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextDecorations="Underline"
                                                       TextTrimming="None"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Border>
                </Border>
                </Grid>
        </Grid>

        <!-- Buttons row with popup overlay (toast shown over the two buttons) -->
        <Grid x:Name="ResultsButtonsPanel" Grid.Row="1" Margin="0,16,0,0">
            <!-- Buttons layer -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResultsDirectoryButton"
                        Content="Results Directory"
                        Style="{StaticResource TealButtonStyle}"
                        Click="ResultsDirectory_Click"
                        Margin="0,0,12,0"/>
                <Button x:Name="ExportExcelButton"
                        Content="Export to Excel"
                        Style="{StaticResource PinkButtonStyle}"
                        Click="ExportExcel_Click"/>
            </StackPanel>
            <!-- In-page export toast: overlays on top of the two buttons (same area, right-aligned) -->
            <Border x:Name="ExportToastCard" Visibility="Collapsed" CornerRadius="10" Padding="16,12" MinWidth="340"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,0"
                    Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Secondary}" BorderThickness="1"
                    Panel.ZIndex="1">
                <Border.Effect>
                    <DropShadowEffect Color="#1AB4CC" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock x:Name="ExportToastTitle" Text="Export Started" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ExportToastMessage" Text="Detection Results Are Being Exported To Excel." FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8,0" VerticalAlignment="Top" Click="ExportToastClose_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Detail view: Session Details (replaces list when View Result is clicked). Panel is created in code-behind to avoid XAML type resolution issues. -->
        <ScrollViewer x:Name="SessionDetailView" Grid.Row="0" Visibility="Collapsed" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <ContentControl x:Name="SessionDetailPanelHost"/>
        </ScrollViewer>
    </Grid>
</UserControl>
