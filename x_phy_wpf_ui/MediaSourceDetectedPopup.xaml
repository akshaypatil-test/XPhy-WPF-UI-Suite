<Window x:Class="x_phy_wpf_ui.MediaSourceDetectedPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="X-PHY"
        Width="440" SizeToContent="Height"
        FontFamily="{DynamicResource AppFontFamily}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="DndListRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="White" CornerRadius="12" Padding="0,0,0,14" BorderThickness="0" BorderBrush="#D0D0D0" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: logo, version, close -->
            <Border Grid.Row="0" Background="#E8F4FC" CornerRadius="10,10,0,0" Padding="12,8,10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/x-phy-inverted-logo.png" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="VersionText" Grid.Column="1" Text="Version: "
                               Foreground="#666666" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Grid.Column="2" Content="✕" Width="24" Height="24"
                            Background="Transparent" Foreground="#333333" FontSize="14"
                            Cursor="Hand" BorderThickness="0" Click="CloseButton_Click"
                            VerticalAlignment="Center" Padding="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0E8F4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- One grid: combo row spans same 3 columns as buttons so width is identical; placeholder is layered on top of combo. -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*" MinWidth="160"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="TitleText" Grid.Row="0" Grid.ColumnSpan="3" Text="[Zoom] Media Source Detected"
                           FontWeight="Bold" FontSize="15" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="Start Detection Now ?"
                           FontSize="13" Foreground="#333333" Margin="0,0,0,12"/>
                <!-- Full-width Do Not Disturb field + Popup list (replaces ComboBox — avoids WPF combo measure/transparent-window bugs). -->
                <Grid x:Name="DndComboHost" Grid.Row="2" Grid.ColumnSpan="3" MinHeight="42" Margin="0,0,0,16">
                    <Border x:Name="DndTriggerBorder" Background="White" BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="8"
                            MinHeight="42" Cursor="Hand" SnapsToDevicePixels="True" UseLayoutRounding="True"
                            MouseLeftButtonDown="DndTriggerBorder_MouseLeftButtonDown">
                        <Grid Margin="14,0,14,0" VerticalAlignment="Center" MinHeight="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DndSelectionText" Grid.Column="0" Text="Do Not Disturb" VerticalAlignment="Center"
                                       Foreground="#333333" FontSize="13"/>
                            <Path Grid.Column="1" Data="M 0 1 L 5 6 L 10 1 Z" Fill="#5C5C5C" Stretch="Uniform" Width="10" Height="6"
                                  VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>
                    <Popup x:Name="DndListPopup" PlacementTarget="{Binding ElementName=DndTriggerBorder}" Placement="Bottom"
                           VerticalOffset="4" AllowsTransparency="True" StaysOpen="True" PopupAnimation="Fade">
                        <Border Background="White" BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="8" Padding="0"
                                MinWidth="{Binding ActualWidth, ElementName=DndTriggerBorder}" SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <StackPanel>
                                <Border Style="{StaticResource DndListRowBorderStyle}" Padding="14,12" MouseLeftButtonDown="DndOptionYes_MouseLeftButtonDown">
                                    <TextBlock Text="Yes" FontSize="13" Foreground="#1A1A1A"/>
                                </Border>
                                <Rectangle Height="1" Fill="#E8E8E8" Margin="12,0"/>
                                <Border Style="{StaticResource DndListRowBorderStyle}" Padding="14,12" MouseLeftButtonDown="DndOptionNo_MouseLeftButtonDown">
                                    <TextBlock Text="No" FontSize="13" Foreground="#1A1A1A"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <Button x:Name="Option1Button" Grid.Row="3" Grid.Column="0" Content="Start conference video"
                        Background="#2563EB" Foreground="White" FontSize="13" FontWeight="SemiBold"
                        Padding="14,10" Cursor="Hand" BorderThickness="0"
                        Click="Option1_Click" HorizontalAlignment="Stretch" MinWidth="160">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="Option2Button" Grid.Row="3" Grid.Column="2" Content="Start conference Audio"
                        Background="#2563EB" Foreground="White" FontSize="13" FontWeight="SemiBold"
                        Padding="14,10" Cursor="Hand" BorderThickness="0"
                        Click="Option2_Click" HorizontalAlignment="Stretch" MinWidth="160">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
